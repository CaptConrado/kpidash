<script type='text/javascript'>
$(function() {
  Dashing.gridsterLayout('[{"col":2,"row":1},{"col":1,"row":1},{"col":3,"row":1},{"col":2,"row":2},{"col":3,"row":2},{"col":1,"row":2},{"col":5,"row":1},{"col":4,"row":2},{"col":2,"row":3}]')
  Dashing.widget_base_dimensions = [370, 340]
  Dashing.numColumns = 5
});
</script>

<% content_for :title do %>Turo KPI TV Dashboard<% end %>

<div class="gridster">
  <ul>
    <li data-row="1" data-col="1" data-sizex="1" data-sizey="1">
      <div data-view="Clock"></div>
      <i class="far fa-clock icon-background"></i>
    </li>

    <li data-row="1" data-col="1" data-sizex="1" data-sizey="1">
      <div data-view="Image" data-image="/logo.png"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="2" data-sizey="1">
      <div data-id="turo_overview" data-view="Text" data-title="Turo Ops Snapshot" data-text="Mock live KPIs" data-moreinfo="Fake data for demo"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="1" data-sizey="1">
      <div data-id="utilization" data-view="Meter" data-title="Fleet Utilization %" data-min="0" data-max="100"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="1" data-sizey="1">
      <div data-id="cancellation" data-view="Meter" data-title="Cancellation Rate %" data-min="0" data-max="10"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="1" data-sizey="2">
      <div data-id="city_hotspots" data-view="List" data-unordered="true" data-title="Top Cities" data-moreinfo="Trips today"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="1" data-sizey="1">
      <div data-id="trips_today" data-view="Number" data-title="Trips Today" style="background-color:#96bf48;"></div>
      <i class="far fa-heart icon-background"></i>
    </li>

    <li data-row="1" data-col="1" data-sizex="2" data-sizey="2">
      <div data-id="bookings_trend" data-view="Graph" data-title="Bookings Trend (7d)" style="background-color:#47bbb3;"></div>
    </li>

    <li data-row="1" data-col="1" data-sizex="2" data-sizey="1">
      <div data-id="ops_alerts" data-view="List" data-unordered="true" style="background-color:#ff9618;" data-title="Ops Alerts" data-moreinfo="Mock status feed"></div>
      <i class="fab fa-twitter icon-background"></i>
    </li>

  </ul>
</div>